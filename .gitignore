# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local

# Claude
CLAUDE.md
AGENTS.md
.claude/

# farma: datos sensibles (descuentos, consumos) — nunca al repo público
/seed

# farma: herramientas que mutan/vuelcan prod — solo local (Pablo las ejecuta desde su
# equipo; los backups contienen datos de prod y no deben tocar el repo público)
/scripts/backups/
/scripts/migrate-descuentos-orden.ts
